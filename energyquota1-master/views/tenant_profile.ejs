<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EnergyQuota – Tenant Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/variables.css" />
    <link rel="stylesheet" href="/css/admin.css" />
    <link rel="stylesheet" href="/css/password.css" />
  </head>
  <body>
    <div class="d-flex" id="wrapper">
      <%- include("partials/sidebar_tenant") %>
      <!-- Page Content -->
      <div id="page-content-wrapper">
        <%- include("partials/header_tenant") %>
        <!-- page contents -->
        <div class="container-fluid p-4 page-content-inner">
          <h2 class="page-title mb-4" style="font-family: var(--font-heading);">Tenant Profile</h2>
          <div class="row">
            <div class="col-lg-6 col-sm-12 mb-4">
              <div class="dashboard-card p-4 h-100">
                <h4 class="text-center mt-3 mb-3" style="font-family: var(--font-heading);">Profile Details</h4>
                <div class="text-center mb-3">
                  <img
                    style="
                      height: 120px;
                      width: 120px;
                      border-radius: 50%;
                      border: 3px solid var(--color-primary);
                      object-fit: cover;
                    "
                    src="/images/user.jpg"
                    alt="User profile"
                  />
                </div>
                <table class="table table-borderless profile-table">
                  <tbody>
                    <tr>
                      <td class="fw-bold text-muted">Name:</td>
                      <td class="fw-semibold text-dark"><%= user.name %></td>
                    </tr>
                    <tr>
                      <td class="fw-bold text-muted">Email:</td>
                      <td class="fw-semibold text-dark"><%= user.email %></td>
                    </tr>
                    <tr>
                      <td class="fw-bold text-muted">Phone number:</td>
                      <td class="fw-semibold text-dark"><%= user.phone_number %></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="col-lg-6 col-sm-12 mb-4">
              <div class="dashboard-card p-4 h-100">
                <h4 class="text-center mt-3 mb-3" style="font-family: var(--font-heading);">Change Password</h4>
                <form action="/tenant_profile/change_password" method="post">
                  <% if(message && (Array.isArray(message) ? message.length > 0 : message)){ %>
                  <div
                    class="alert alert-info alert-dismissible fade show"
                    role="alert"
                  >
                    <%= Array.isArray(message) ? message[0] : message %>
                    <button
                      type="button"
                      class="btn-close"
                      data-bs-dismiss="alert"
                      aria-label="Close"
                    ></button>
                  </div>
                  <% } %>
                  <div class="mb-3">
                    <label for="old_password" class="form-label">Old password</label>
                    <div class="input-box">
                      <input type="password" name="old_password" class="form-control" id="old_password" placeholder="Enter your current password" required />
                      <img
                        id="toggle-btn-old"
                        onclick="toggleOldPassword()"
                        src="/images/eye-close.png"
                        alt="Toggle password visibility"
                        role="button"
                      />
                    </div>
                  </div>
                  <div class="mb-3">
                    <label for="new_password" class="form-label">New password</label>
                    <div class="input-box">
                      <input
                        type="password"
                        name="password"
                        class="form-control"
                        id="password"
                        placeholder="Min 8 chars, 1 digit, 1 uppercase, 1 lowercase"
                        pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}$"
                        title="Password must be at least 8 characters long and include at least one digit, one lowercase letter, and one uppercase letter"
                        required
                      />
                      <img
                        id="toggle-btn"
                        onclick="togglePassword()"
                        src="/images/eye-close.png"
                        alt="Toggle password visibility"
                        role="button"
                      />
                    </div>
                  </div>
                  <div class="mb-3">
                    <label for="confirm_password" class="form-label">Confirm password</label>
                    <div class="input-box">
                      <input
                        type="password"
                        name="confirm_password"
                        class="form-control"
                        id="confirm_password"
                        placeholder="Re-enter your password"
                        required
                      />
                      <img
                        id="toggle-btn-confirm"
                        onclick="togglePasswordConfirm()"
                        src="/images/eye-close.png"
                        alt="Toggle password visibility"
                        role="button"
                      />
                    </div>
                  </div>
                  <button type="submit" class="btn btn-primary-auth">Submit</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script src="/js/index.js"></script>
    <script src="/js/toggle_password_view.js"></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
