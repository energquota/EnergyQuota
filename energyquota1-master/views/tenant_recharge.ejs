<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EnergyQuota – Buy Units</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/variables.css" />
    <link rel="stylesheet" href="/css/admin.css" />
    <link rel="stylesheet" href="/css/custom_grid.css" />
  </head>
  <body>
    <div class="d-flex" id="wrapper">
      <%- include("partials/sidebar_tenant") %>
      <!-- Page Content -->
      <div id="page-content-wrapper">
        <%- include("partials/header_tenant") %>
        <!-- page contents -->
        <div class="container-fluid p-4 page-content-inner">
          <h2 class="page-title mb-4" style="font-family: var(--font-heading);">Buy Units</h2>
          <hr class="page-divider" />

          <% if(message && (Array.isArray(message) ? message.length > 0 : message)){ %>
            <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                 <%= Array.isArray(message) ? message[0] : message %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>

          <div class="mb-5">
            <h4 class="p-2 text-center" style="font-family: var(--font-heading);">Quick Selections</h4>
            <div class="container-div">
              <div class="grid-container-3 dashboard-card text-center recharge-option" style="background: var(--color-bg-sidebar); cursor: pointer;">
                <p class="mb-2" style="color: var(--color-text-dark);"> 
                  <span class="recharge-value">10</span> 
                  <span style="font-size: var(--text-h4); color: var(--color-text-muted);">kWh</span>
                </p>
                <form action="/tenant_recharge/units" method="post">
                  <input type="hidden" name="units_value" value="10.00">
                  <button type="submit" class="btn btn-primary-auth" style="background: var(--color-primary); border-color: var(--color-primary);">Buy</button>
                </form>
              </div>
              <div class="grid-container-3 dashboard-card dashboard-card-primary text-center recharge-option" style="cursor: pointer;">
                <p class="mb-2 text-white"> 
                  <span class="recharge-value">15</span> 
                  <span style="font-size: var(--text-h4); opacity: 0.8;">kWh</span>
                </p>
                <form action="/tenant_recharge/units" method="post">
                  <input type="hidden" name="units_value" value="15.00">
                  <button type="submit" class="btn btn-light" style="color: var(--color-primary);">Buy</button>
                </form>
              </div>
              <div class="grid-container-3 dashboard-card text-center recharge-option" style="background: var(--color-bg-sidebar); cursor: pointer;">
                <p class="mb-2" style="color: var(--color-text-dark);"> 
                  <span class="recharge-value">20</span> 
                  <span style="font-size: var(--text-h4); color: var(--color-text-muted);">kWh</span>
                </p>
                <form action="/tenant_recharge/units" method="post">
                  <input type="hidden" name="units_value" value="20.00">
                  <button type="submit" class="btn btn-primary-auth" style="background: var(--color-primary); border-color: var(--color-primary);">Buy</button>
                </form>
              </div>
            </div>
          </div>

          <div class="row justify-content-center mt-4 p-3">
            <div class="col-lg-6">
              <div class="dashboard-card p-4" style="background: var(--color-bg-card);">
                <h4 class="text-center mb-3" style="font-family: var(--font-heading); color: var(--color-text-dark);">Custom Units</h4>
                <form action="/tenant_recharge/units" method="post">
                  <div class="mb-3">
                    <label for="units" class="form-label">Enter amount (kWh)</label>
                    <input type="number" step="0.0000000001" min="0.0000000001" class="form-control" name="units_value" id="units" placeholder="e.g. 25.50" required>
                  </div>
                  <button type="submit" class="btn btn-primary-auth w-100">Buy Units</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script src="/js/index.js"></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
